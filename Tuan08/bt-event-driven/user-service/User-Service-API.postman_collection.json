{
  "info": {
    "name": "User Service - Mini Food Ordering System",
    "description": "API Collection for User Service (Port 8081)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('token', jsonData.token);",
                  "    pm.environment.set('userId', jsonData.userId);",
                  "    pm.environment.set('username', jsonData.username);",
                  "    console.log('Register successful. Token saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"email\": \"newuser@company.vn\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\",\n  \"fullName\": \"New User\",\n  \"phone\": \"090123457\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "register"
              ]
            },
            "description": "Register a new user account"
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('token', jsonData.token);",
                  "    pm.environment.set('userId', jsonData.userId);",
                  "    pm.environment.set('username', jsonData.username);",
                  "    console.log('Login successful. Token: ' + jsonData.token.substring(0, 20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "login"
              ]
            },
            "description": "Login with username and password"
          },
          "response": []
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"{{token}}\""
            },
            "url": {
              "raw": "{{base_url}}/api/users/verify-token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "verify-token"
              ]
            },
            "description": "Verify JWT token validity (can be used by other services)"
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "logout"
              ]
            },
            "description": "Logout and blacklist current token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. User Management",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users"
              ]
            },
            "description": "Get list of all users"
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/2",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "2"
              ]
            },
            "description": "Get user by ID (example: 2)"
          },
          "response": []
        },
        {
          "name": "Get User by Username",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/username/admin",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "username",
                "admin"
              ]
            },
            "description": "Get user by username (example: admin)"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "username",
      "value": "",
      "type": "string"
    }
  ]
}
